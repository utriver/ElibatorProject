<Window x:Class="ElevatorPanel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Elevator Control Panel" Height="680" Width="1000"
        Background="#FF111111">

    <Window.Resources>
        <!-- 층 버튼 스타일 (파란 사각형) -->
        <Style x:Key="FloorButtonStyle" TargetType="Border">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="80"/>
            <Setter Property="Background" Value="#FF3355CC"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Margin" Value="0,6"/>
        </Style>

        <!-- 슬라이드 스위치 베이스 (회색) -->
        <Style x:Key="SwitchBaseStyle" TargetType="Border">
            <Setter Property="Width" Value="90"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Background" Value="#FF555555"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

        <!-- 슬라이드 스위치 핸들 (파란색) -->
        <Style x:Key="SwitchHandleOnStyle" TargetType="Border">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Background" Value="#FF4477FF"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <!-- 슬라이드 스위치 핸들 OFF (빨간) -->
        <Style x:Key="SwitchHandleOffStyle" TargetType="Border">
            <Setter Property="Width" Value="35"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Background" Value="#FFCC2222"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <!-- 방향 버튼 (▲▼ 파란색) -->
        <Style x:Key="ArrowBtnStyle" TargetType="Border">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Background" Value="#FF3355CC"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Margin" Value="0,1"/>
        </Style>

        <!-- LED 원형 (회색 = OFF) -->
        <Style x:Key="LedOffStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Fill" Value="#FF777777"/>
            <Setter Property="Margin" Value="4,1"/>
        </Style>

        <!-- LED 원형 (빨강 = ON) -->
        <Style x:Key="LedOnStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Fill" Value="#FFEE2222"/>
            <Setter Property="Margin" Value="4,1"/>
        </Style>

        <!-- 둥근 제어 버튼 -->
        <Style x:Key="RoundCtrlStyle" TargetType="Border">
            <Setter Property="Width" Value="54"/>
            <Setter Property="Height" Value="54"/>
            <Setter Property="CornerRadius" Value="27"/>
            <Setter Property="Background" Value="#FF666666"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <!-- 층 버튼 -->
            <ColumnDefinition Width="280"/>
            <!-- 스위치 + 샤프트 -->
            <ColumnDefinition Width="*"/>
            <!-- 오른쪽 패널 -->
        </Grid.ColumnDefinitions>

        <!-- ===================== 왼쪽: 층 버튼 ===================== -->
        <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">

            <!-- 5층 -->
            <Border Style="{StaticResource FloorButtonStyle}">
                <Grid>
                    <TextBlock Text="5층" Foreground="White" FontSize="16" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- 4층 -->
            <Border Style="{StaticResource FloorButtonStyle}">
                <TextBlock Text="4층" Foreground="White" FontSize="16" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- 3층 -->
            <Border Style="{StaticResource FloorButtonStyle}">
                <TextBlock Text="3층" Foreground="White" FontSize="16" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- 2층 -->
            <Border Style="{StaticResource FloorButtonStyle}">
                <TextBlock Text="2층" Foreground="White" FontSize="16" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- 1층 -->
            <Border Style="{StaticResource FloorButtonStyle}">
                <TextBlock Text="1층" Foreground="White" FontSize="16" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </StackPanel>

        <!-- ===================== 가운데: 스위치 + 샤프트 ===================== -->
        <Border Grid.Column="1" BorderBrush="#FF888888" BorderThickness="2"
                Margin="10,0" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <!-- 스위치 2열 -->
                    <ColumnDefinition Width="80"/>
                    <!-- 엘리베이터 칸 -->
                    <ColumnDefinition Width="60"/>
                    <!-- 버튼+LED -->
                </Grid.ColumnDefinitions>

                <!-- 스위치 영역 -->

                <!-- 엘리베이터 칸 (회색 사각형들) -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="5,0">
                    <Border Height="95" Background="#FF888888" Margin="0,4" CornerRadius="2"/>
                    <Border Height="95" Background="#FF888888" Margin="0,4" CornerRadius="2"/>
                    <Border Height="95" Background="#FF888888" Margin="0,4" CornerRadius="2"/>
                    <Border Height="95" Background="#FF888888" Margin="0,4" CornerRadius="2"/>
                    <Border Height="95" Background="#FF888888" Margin="0,4" CornerRadius="2"/>
                </StackPanel>

                <!-- 방향 버튼 + LED -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center">

                    <!-- 5층: ▼ + LED -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,60" HorizontalAlignment="Center">
                        <Border Style="{StaticResource ArrowBtnStyle}">
                            <TextBlock Text="▼" Foreground="White" FontSize="11"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Ellipse Style="{StaticResource LedOffStyle}"/>
                    </StackPanel>

                    <!-- 4층: ▲▼ + LED 2개 -->
                    <StackPanel Margin="0,0,0,54" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource ArrowBtnStyle}">
                                <TextBlock Text="▲" Foreground="White" FontSize="11"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Ellipse Style="{StaticResource LedOffStyle}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource ArrowBtnStyle}">
                                <TextBlock Text="▼" Foreground="White" FontSize="11"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Ellipse Style="{StaticResource LedOffStyle}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 3층: ▲▼ + LED 2개 -->
                    <StackPanel Margin="0,0,0,54" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource ArrowBtnStyle}">
                                <TextBlock Text="▲" Foreground="White" FontSize="11"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Ellipse Style="{StaticResource LedOffStyle}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource ArrowBtnStyle}">
                                <TextBlock Text="▼" Foreground="White" FontSize="11"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Ellipse Style="{StaticResource LedOnStyle}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 2층: ▲▼ + LED 2개 -->
                    <StackPanel Margin="0,0,0,54" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource ArrowBtnStyle}">
                                <TextBlock Text="▲" Foreground="White" FontSize="11"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Ellipse Style="{StaticResource LedOffStyle}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource ArrowBtnStyle}">
                                <TextBlock Text="▼" Foreground="White" FontSize="11"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Ellipse Style="{StaticResource LedOffStyle}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 1층: ▲ + LED -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Border Style="{StaticResource ArrowBtnStyle}">
                            <TextBlock Text="▲" Foreground="White" FontSize="11"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Ellipse Style="{StaticResource LedOffStyle}"/>
                    </StackPanel>

                </StackPanel>
            </Grid>
        </Border>

        <!-- ===================== 오른쪽: 상태 패널 ===================== -->
        <Grid Grid.Column="2" Margin="20,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 상단: 방향 표시 + 7세그먼트 -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 방향 삼각형 -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <!-- 위 삼각형 (빨강 = 상승 중) -->
                    <Polygon Points="60,0 120,80 0,80" Fill="#FFEE2222" Margin="0,0,0,16"
                             HorizontalAlignment="Center"/>
                    <!-- 아래 삼각형 (회색 = 비활성) -->
                    <Polygon Points="0,0 120,0 60,80" Fill="#FF666666"
                             HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- 7세그먼트 숫자 표시 -->
                <Grid Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!-- 7세그먼트 모양 (숫자 1 예시) -->
                    <StackPanel>
                        <!-- 상단 가로 세그먼트 -->
                        <!-- 중단 가로 세그먼트 -->
                        <StackPanel Orientation="Horizontal" Margin="0,4"/>
                        <!-- 중간 가로 세그먼트 -->
                        <!-- 하단 가로 세그먼트 -->
                        <StackPanel Orientation="Horizontal" Margin="0,4"/>
                        <!-- 최하단 가로 세그먼트 -->
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- 하단: 현재층 숫자 + 제어 버튼 -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 현재 층 숫자 + 제어버튼 -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <!-- 현재 층 숫자 (픽셀 폰트 느낌) -->

                    <!-- 고장 버튼 -->
                    <Border Style="{StaticResource RoundCtrlStyle}" HorizontalAlignment="Center" Margin="0,6">
                        <TextBlock Text="고장" Foreground="White" FontSize="13" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- 정지 / 운전 버튼 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6">
                        <Border Style="{StaticResource RoundCtrlStyle}" Margin="4,0">
                            <TextBlock Text="정지" Foreground="White" FontSize="13" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Width="54" Height="54" CornerRadius="27"
                                Background="#FFCC2222" Margin="4,0">
                            <TextBlock Text="운전" Foreground="White" FontSize="13" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- 빨강 / 초록 큰 표시등 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,20">
                    <Border Width="90" Height="90" Background="#FFCC2222" CornerRadius="6" Margin="6,0"/>
                    <Border Width="90" Height="90" Background="#FF44CC44" CornerRadius="6" Margin="6,0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
